generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              BigInt           @id @default(autoincrement())
  name            String
  email           String           @unique
  phone           String?          @unique
  emailVerifiedAt DateTime?        @map("email_verified_at")
  password        String
  isBanned        Boolean          @default(false) @map("is_Banned")
  roles           String           @default("[\"user\"]")
  rememberToken   String?          @map("remember_token")
  createdAt       DateTime?        @default(now()) @map("created_at")
  updatedAt       DateTime?        @updatedAt @map("updated_at")
  forms           Form[]
  payments        Payment[]
  interviews      Interview[]
  examHistories   ExamHistory[]
  medicalCheckUps MedicalCheckUp[]

  @@map("users")
}

model WebSetting {
  id                   BigInt    @id @default(autoincrement())
  name                 String?
  siteName             String?   @map("site_name")
  shortName            String?   @map("short_name")
  titleHome            String?   @map("title_home")
  titleDashboard       String?   @map("title_dashboard")
  titleExam            String?   @map("title_exam")
  institutionName      String?   @map("institution_name")
  institutionShortName String?   @map("institution_short_name")
  institutionSynopsis  String?   @map("institution_synopsis")
  institutionVision    String?   @map("institution_vision_mission") @db.Text
  institutionHistory   String?   @map("institution_history") @db.Text
  footer               String?   @db.Text
  linkUniv             String?   @map("link_univ")
  contactTelp          String?   @map("contact_telp")
  contactEmail         String?   @map("contact_email")
  contactAddress       String?   @map("contact_address")
  contactWhatsapp      String?   @map("contact_whatsapp")
  contactMaps          String?   @map("contact_maps") @db.Text
  contactMapsLink      String?   @map("contact_maps_link") @db.Text
  paymentBank          String?   @map("payment_bank")
  paymentAccount       String?   @map("payment_account")
  paymentName          String?   @map("payment_name")
  logo                 String?
  favicon              String?
  cover                String?
  brochure             String?
  costDetails          String?   @map("cost_details")
  cr                   String
  createdAt            DateTime? @default(now()) @map("created_at")
  updatedAt            DateTime? @updatedAt @map("updated_at")

  @@map("web_settings")
}

model Wave {
  id            BigInt    @id @default(autoincrement())
  code          String?
  gelombang     String?
  tahunAkademik String?   @map("tahun_akademik")
  awalDaftar    DateTime? @map("awal_daftar") @db.Date
  akhirDaftar   DateTime? @map("akhir_daftar") @db.Date
  tesTulis      DateTime? @map("tes_tulis") @db.Date
  tesKesehatan  DateTime? @map("tes_kesehatan") @db.Date
  wawancara     DateTime? @db.Date
  active        Boolean   @default(false)
  createdAt     DateTime? @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  forms         Form[]

  @@map("waves")
}

model Prodi {
  id              BigInt    @id @default(autoincrement())
  namaProdi       String?   @map("nama_prodi")
  jenjang         String?
  fakultas        String?
  akreditasi      String?
  tesUjian        Boolean   @default(false) @map("tes_ujian")
  nilaiDibawah    Int?      @map("nilai_dibawah")
  tesWawancara    Boolean   @default(false) @map("tes_wawancara")
  tesKesehatan    Boolean   @default(false) @map("tes_kesehatan")
  biayaRegistrasi Int       @default(0) @map("biaya_registrasi")
  status          Boolean   @default(false)
  createdAt       DateTime? @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")

  @@map("prodis")
}

model Form {
  id                 BigInt    @id @default(autoincrement())
  user               User      @relation(fields: [userId], references: [id])
  userId             BigInt    @map("user_id")
  gender             String?
  religion           String?
  birthDate          DateTime? @map("birth_date") @db.Date
  birthPlaceCity     String?   @map("birth_place_city")
  birthPlaceProvince String?   @map("birth_place_province")
  nationalId         String?   @map("national_id")
  address            String?
  city               String?
  province           String?
  phoneNumber        String?   @map("phone_number")
  lastEducation      String?   @map("last_education")
  educationName      String?   @map("education_name")
  fatherName         String?   @map("father_name")
  motherName         String?   @map("mother_name")
  wave               Wave?     @relation(fields: [waveId], references: [id])
  waveId             BigInt?   @map("wave_id")
  noExam             String?   @map("no_exam")
  codeRegistration   String    @default("0") @map("code_registration")
  isViaOnline        Boolean   @default(true) @map("is_via_online")
  isLock             Boolean   @default(false) @map("is_lock")
  status             String    @default("waiting")
  isPaidRegistration DateTime? @map("is_paid_registration")
  isPaidTuition      Boolean   @default(false) @map("is_paid_tuition")
  createdAt          DateTime? @default(now()) @map("created_at")
  updatedAt          DateTime? @updatedAt @map("updated_at")

  @@map("forms")
}

model Payment {
  id            BigInt    @id @default(autoincrement())
  user          User      @relation(fields: [userId], references: [id])
  userId        BigInt    @map("user_id")
  bank          String?
  accountName   String?   @map("account_name")
  accountNumber String?   @map("account_number")
  amount        String?
  date          DateTime? @db.Date
  code          String?
  typePayment   String    @default("form") @map("type_payment")
  status        String    @default("pending")
  note          String?
  createdAt     DateTime? @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")

  @@map("payments")
}

model Exam {
  id              BigInt         @id @default(autoincrement())
  name            String
  description     String?        @db.Text
  duration        Int            @default(60)
  shuffleQuestion Boolean        @default(false) @map("shuffle_question")
  shuffleAnswer   Boolean        @default(false) @map("shuffle_answer")
  showResult      Boolean        @default(false) @map("show_result")
  isActive        Boolean        @default(false) @map("is_active")
  createdAt       DateTime?      @default(now()) @map("created_at")
  updatedAt       DateTime?      @updatedAt @map("updated_at")
  examHistories   ExamHistory[]
  examQuestions   ExamQuestion[]

  @@map("exams")
}

model ExamHistory {
  id         BigInt    @id @default(autoincrement())
  exam       Exam      @relation(fields: [examId], references: [id])
  examId     BigInt    @map("exam_id")
  user       User      @relation(fields: [userId], references: [id])
  userId     BigInt    @map("user_id")
  score      Int       @default(0)
  duration   Int       @default(0)
  isActive   Boolean   @default(false) @map("is_active")
  isFinished Boolean   @default(false) @map("is_finished")
  startedAt  DateTime? @map("started_at")
  finishedAt DateTime? @map("finished_at")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@map("exam_histories")
}

model ExamQuestion {
  id        BigInt    @id @default(autoincrement())
  exam      Exam      @relation(fields: [examId], references: [id])
  examId    BigInt    @map("exam_id")
  question  String    @db.Text
  optionA   String?   @map("option_a")
  optionB   String?   @map("option_b")
  optionC   String?   @map("option_c")
  optionD   String?   @map("option_d")
  optionE   String?   @map("option_e")
  answer    String
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("exam_questions")
}

model Interview {
  id            BigInt    @id @default(autoincrement())
  user          User      @relation(fields: [userId], references: [id])
  userId        BigInt    @map("user_id")
  noExam        String?   @map("no_exam")
  interviewDate DateTime? @map("interview_date")
  note          String?   @db.Text
  status        String    @default("pending")
  createdAt     DateTime? @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")

  @@map("interviews")
}

model MedicalCheckUp {
  id         BigInt    @id @default(autoincrement())
  user       User      @relation(fields: [userId], references: [id])
  userId     BigInt    @map("user_id")
  height     String?
  weight     String?
  bloodType  String?   @map("blood_type")
  isSmoking  Boolean   @default(false) @map("is_smoking")
  colorBlind Boolean   @default(false) @map("color_blind")
  note       String?   @db.Text
  status     String    @default("waiting")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  @@map("medical_check_ups")
}
